        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            background: #0a0a0a;
            color: white;
            font-family: Arial, sans-serif;
            overflow-x: hidden;
        }

        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 30px;
            padding: 15px 20px;
            background: rgba(0,0,0,0.9);
            backdrop-filter: blur(10px);
            z-index: 100;
            flex-wrap: wrap;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .navbar a:hover { color: #aaa; }

        .discord-btn {
            margin-left: 20px;
            display: flex;
            align-items: center;
            background: #3c44a5;
            padding: 8px 14px;
            border-radius: 8px;
            font-weight: bold;
            color: white;
            text-decoration: none;
        }

        .discord-btn:hover { background: #2f357f; }

        section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding-top: 60px;
            scroll-margin-top: 60px;
        }

        h1 {
            font-size: 6rem;
            letter-spacing: 0.2em;
            background: linear-gradient(90deg, #222, #fff, #222);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 3s infinite linear;
        }

        @keyframes shine {
            0% { background-position: -200%; }
            100% { background-position: 200%; }
        }

        button {
            margin-top: 20px;
            padding: 14px 32px;
            font-size: 1.3rem;
            border: 1px solid white;
            cursor: pointer;
            background: #111;
            color: white;
            border-radius: 8px;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        button:hover {
            background: white;
            color: black;
        }

        .notification {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            color: black;
            padding: 15px 30px;
            border-radius: 8px;
            opacity: 0;
            transition: opacity 0.5s, transform 0.5s;
            z-index: 200;
            font-weight: bold;
        }

        .notification.show {
            opacity: 1;
            transform: translateX(-50%) translateY(-10px);
        }

        .about-text, .help-text {
            max-width: 800px;
            padding: 20px;
            line-height: 1.6;
        }

        table {
            border-collapse: collapse;
            margin: 20px 0;
            width: 90%;
            max-width: 800px;
        }

        th, td {
            border: 1px solid white;
            padding: 10px;
        }

        th { background: #111; }

        a.link {
            color: #aaa;
            text-decoration: underline;
            cursor: pointer;
        }

        .feature-card {
            position: relative;
            background: #111;
            padding: 20px;
            border-radius: 16px;
            width: 220px;
            box-shadow: 0 0 15px rgba(255,255,255,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            overflow: hidden;
        }

        .feature-card:hover {
            transform: scale(1.08);
            box-shadow: 0 0 25px rgba(255,255,255,0.25);
        }

        .big-box {
            margin-top: 40px;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
            padding: 30px;
            border-radius: 20px;
            background: rgba(255,255,255,0.05);
            box-shadow: 0 0 25px rgba(255,255,255,0.08);
            backdrop-filter: blur(8px);
        }

        .box-item {
            width: 170px;
            height: 140px;
            padding: 12px;
            border-radius: 16px;
            background: rgba(0,0,0,0.6);
            box-shadow: 0 0 15px rgba(255,255,255,0.1);
            transition: 0.3s ease;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: center;
            overflow: hidden;
        }

        .box-item:hover {
            transform: scale(1.08);
            box-shadow: 0 0 25px rgba(255,255,255,0.25);
        }

        .box-item h3, .box-item p {
            font-size: 0.9rem !important;
            line-height: 1.1;
            margin: 2px 0;
        }

        /* Ripple effect */
        .ripple {
            position: fixed;
            border-radius: 50%;
            transform: scale(0);
            animation: rippleEffect 0.6s ease-out;
            background: rgba(255,255,255,0.3);
            pointer-events: none;
            z-index: 9999;
        }

        @keyframes rippleEffect {
            to { transform: scale(4); opacity: 0; }
        }

        /* Background effects */
        body::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image: url('https://grainy-gradients.vercel.app/noise.svg');
            opacity: 0.05;
            z-index: 9998;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background: radial-gradient(circle at 50% 40%, rgba(255,255,255,0.15), transparent 65%),
                        linear-gradient(135deg, rgba(255,255,255,0.05), transparent 60%);
            opacity: 0.6;
            z-index: 9997;
        }

        .footer {
            width: 100%;
            text-align: center;
            padding: 18px;
            font-size: 1.2rem;
            background: linear-gradient(180deg, rgba(20,20,20,0.95), rgba(10,10,10,0.95));
            border-top: 1px solid #333;
            border-radius: 16px 16px 0 0;
            margin-top: 60px;
            box-shadow: 0 -10px 25px rgba(255,255,255,0.08);
            backdrop-filter: blur(6px);
        }
    </style>
</head>
